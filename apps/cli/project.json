{
    "name": "cli",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/cli/src",
    "projectType": "application",
    "tags": ["scope:cli"],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "tsup",
                "cwd": "apps/cli"
            },
            "dependsOn": ["^build"]
        },
        "dev": {
            "executor": "nx:run-commands",
            "options": {
                "command": "tsup --watch",
                "cwd": "apps/cli"
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vitest run",
                "cwd": "apps/cli"
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "eslint src",
                "cwd": "apps/cli"
            }
        },
        "type-check": {
            "executor": "nx:run-commands",
            "options": {
                "command": "tsc --noEmit",
                "cwd": "apps/cli"
            }
        }
    }
}
