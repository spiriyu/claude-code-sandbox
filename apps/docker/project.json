{
    "name": "docker",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "tags": ["scope:docker"],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "docker build -f image/Dockerfile --build-arg USER_UID=$(id -u) --build-arg USER_GID=$(id -g) -t claude-code-sandbox .",
                "cwd": "apps/docker"
            }
        },
        "generate-matrix": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node scripts/generate-matrix.js",
                "cwd": "apps/docker"
            }
        }
    }
}
