# ===================================
# Claude Code CLI Sandbox
# Alpine 3.21 with nvm + pyenv
# ===================================

FROM alpine:3.21

# ---- Install bash first, then set as default shell ----
RUN apk add --no-cache bash
SHELL ["/bin/bash", "-c"]

# ---- System packages (single layer) ----
RUN apk add --no-cache \
    coreutils \
    git \
    curl \
    wget \
    vim \
    jq \
    build-base \
    ripgrep \
    fzf \
    tmux \
    unzip \
    tree \
    htop \
    ca-certificates \
    gnupg \
    shadow \
    # pyenv build dependencies
    openssl-dev \
    zlib-dev \
    bzip2-dev \
    readline-dev \
    sqlite-dev \
    ncurses-dev \
    xz-dev \
    tk-dev \
    libxml2-dev \
    xmlsec-dev \
    libffi-dev \
    linux-headers

# Set locale
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

# ---- Non-root user ----
ARG USER_UID=1000
ARG USER_GID=1000

# Handle case where GID already exists (e.g., macOS GID 20 = Alpine dialout)
# shadow package provides groupadd/useradd for consistent behavior
RUN if getent group ${USER_GID} > /dev/null 2>&1; then \
      EXISTING_GROUP=$(getent group ${USER_GID} | cut -d: -f1); \
      useradd --uid ${USER_UID} --gid ${EXISTING_GROUP} --create-home --shell /bin/bash dev; \
    else \
      groupadd --gid ${USER_GID} dev; \
      useradd --uid ${USER_UID} --gid dev --create-home --shell /bin/bash dev; \
    fi

# ---- Working directory ----
RUN mkdir -p /workspace && chown dev /workspace

# Switch to non-root user for nvm, pyenv, and claude installs
USER dev
WORKDIR /home/dev

# Create shell profiles (Alpine useradd doesn't create them)
RUN touch /home/dev/.bashrc /home/dev/.profile

# ---- nvm + Node.js ----
ENV NODE_VERSION=22
ENV NVM_DIR=/home/dev/.nvm
# Official Node.js has no prebuilt musl binaries — use unofficial builds mirror
ENV NVM_NODEJS_ORG_MIRROR=https://unofficial-builds.nodejs.org/download/release

RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash \
    && . "${NVM_DIR}/nvm.sh" \
    && nvm install $NODE_VERSION \
    && nvm alias default $NODE_VERSION \
    && nvm cache clear

# Add nvm init to .bashrc and .profile for docker exec sessions
RUN echo '' >> /home/dev/.bashrc \
    && echo '# nvm' >> /home/dev/.bashrc \
    && echo 'export NVM_DIR="/home/dev/.nvm"' >> /home/dev/.bashrc \
    && echo 'export NVM_NODEJS_ORG_MIRROR=https://unofficial-builds.nodejs.org/download/release' >> /home/dev/.bashrc \
    && echo '[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"' >> /home/dev/.bashrc \
    && echo '[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"' >> /home/dev/.bashrc \
    && echo '' >> /home/dev/.profile \
    && echo '# nvm' >> /home/dev/.profile \
    && echo 'export NVM_NODEJS_ORG_MIRROR=https://unofficial-builds.nodejs.org/download/release' >> /home/dev/.profile \
    && echo 'export NVM_DIR="/home/dev/.nvm"' >> /home/dev/.profile \
    && echo '[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"' >> /home/dev/.profile

# ---- pyenv + Python ----
ENV PYTHON_VERSION=3.13
ENV PYENV_ROOT=/home/dev/.pyenv
ENV PATH="${PYENV_ROOT}/bin:${PYENV_ROOT}/shims:${PATH}"

RUN curl https://pyenv.run | bash \
    && echo '' >> /home/dev/.bashrc \
    && echo '# pyenv' >> /home/dev/.bashrc \
    && echo 'export PYENV_ROOT="/home/dev/.pyenv"' >> /home/dev/.bashrc \
    && echo 'export PATH="$PYENV_ROOT/bin:$PATH"' >> /home/dev/.bashrc \
    && echo 'eval "$(pyenv init -)"' >> /home/dev/.bashrc \
    && echo '' >> /home/dev/.profile \
    && echo '# pyenv' >> /home/dev/.profile \
    && echo 'export PYENV_ROOT="/home/dev/.pyenv"' >> /home/dev/.profile \
    && echo 'export PATH="$PYENV_ROOT/bin:$PATH"' >> /home/dev/.profile \
    && echo 'eval "$(pyenv init -)"' >> /home/dev/.profile

RUN pyenv install $PYTHON_VERSION && pyenv global $PYTHON_VERSION

# ---- Claude Code CLI (via npm — native musl binary is incompatible with Alpine) ----
RUN . "${NVM_DIR}/nvm.sh" && npm install -g @anthropic-ai/claude-code \
    && echo '' >> /home/dev/.bashrc \
    && echo '# claude code' >> /home/dev/.bashrc \
    && echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/dev/.bashrc \
    && echo '' >> /home/dev/.profile \
    && echo '# claude code' >> /home/dev/.profile \
    && echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/dev/.profile


# INIT CLAUDE
COPY --chown=dev ./docker/src/.claude.json /home/dev/.claude.json

# ---- Entrypoint ----
WORKDIR /workspace

ENTRYPOINT ["/bin/bash", "-lc", "claude --dangerously-skip-permissions"]
