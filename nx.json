{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "main",
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "sharedGlobals": ["{workspaceRoot}/tsconfig.base.json"]
    },
    "targetDefaults": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["default"],
            "cache": true
        },
        "test": {
            "inputs": ["default"],
            "cache": true
        },
        "lint": {
            "inputs": ["default"],
            "cache": true
        }
    },
    "plugins": []
}
